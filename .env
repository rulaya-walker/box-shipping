# Stripe Configuration
# Replace these with your actual Stripe keys from https://dashboard.stripe.com/

# Publishable key (safe to expose in frontend)
VITE_REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_51234567890abcdef...

# Secret key (NEVER expose in frontend - use in backend only)
# STRIPE_SECRET_KEY=sk_test_51234567890abcdef...

# Webhook endpoint secret (for backend webhook handling)
# STRIPE_WEBHOOK_SECRET=whsec_1234567890abcdef...

# Other environment variables
VITE_APP_COMPANY_NAME=Box Shipping Co.
VITE_APP_SUPPORT_EMAIL=support@boxshipping.com
VITE_BACKEND_URL=http://localhost:9000
